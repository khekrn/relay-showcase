{
  "name": "dispatcher",
  "version": 1,
  "mode": "ASYNC_STICKY",
  "output": "${default(express.output, default(standard.output, review.output))}",
  "start": "classify",
  "states": {
    "classify": {
      "type": "DYNAMIC",
      "dynamic": { "kind": "ROUTE", "candidates": ["express", "standard", "review"] },
      "input": { "amount": "${input.amount}" },
      "next": "review"
    },
    "express":  { "type": "TASK", "task": "handle", "input": { "action": "EXPRESS" },  "end": true },
    "standard": { "type": "TASK", "task": "handle", "input": { "action": "STANDARD" }, "end": true },
    "review":   { "type": "TASK", "task": "handle", "input": { "action": "REVIEW" },   "end": true }
  }
}
